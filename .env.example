# ─────────────────────────────────────────────────────────────
# AutoCrypt — environment variable template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored and must NEVER be committed.
# This `.env.example` is tracked — keep it free of real secrets.
# Use empty placeholders only. (See CLAUDE.md §3 RED + §4.)
# ─────────────────────────────────────────────────────────────

# ── Runtime ──
# paper | backtest | live   (live is a RED transition — never set autonomously)
APP_ENV=backtest
LOG_LEVEL=INFO

# ── On-chain data: historical truth / backfill layer ──
# Dune — PRIMARY decoded archive, free Community key (dune.com → Settings → API)
DUNE_API_KEY=
# Bitquery — raw streaming + deep historical backfill (Phase 1)
BITQUERY_API_KEY=

# ── On-chain data: live Solana terminal ──
# Birdeye — real-time low-cap Solana data
BIRDEYE_API_KEY=

# ── Cheap-breadth free tiers (optional cross-check) ──
DEXPAPRIKA_API_KEY=
GECKOTERMINAL_API_KEY=
COINGECKO_API_KEY=

# ── Wallet labels / smart-money seeds (optional) ──
NANSEN_API_KEY=
ARKHAM_API_KEY=

# ── Solana RPC (read-only for Phases 1–4) ──
# e.g. Helius / Triton / QuickNode endpoint URL
SOLANA_RPC_URL=
SOLANA_RPC_API_KEY=

# ── Alerting (Phase 5+) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Local data store paths (override defaults if desired) ──
# DATA_DIR=./data
# DB_URL=duckdb:///data/autocrypt.duckdb
