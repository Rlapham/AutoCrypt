# ─────────────────────────────────────────────────────────────
# AutoCrypt .gitignore
# Python 3.11+ on-chain data ingestion / backtesting project.
# Load-bearing rule: NEVER commit secrets or raw data stores.
# ─────────────────────────────────────────────────────────────

# ── Secrets & credentials (RED — must never be tracked) ──
.env
.env.*
!.env.example
*.env
secrets/
secret/
*.key
*.pem
*.keystore
*.seed
*seed-phrase*
*mnemonic*
*wallet*.json
credentials.json
service-account*.json
.netrc

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ── Packaging / dependency tooling ──
pip-log.txt
pip-delete-this-directory.txt
.pdm.toml
__pypackages__/

# ── Testing / coverage / type checking ──
.pytest_cache/
.cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyre/
.pytype/

# ── Jupyter / notebooks ──
.ipynb_checkpoints/
*-checkpoint.ipynb
profile_default/
ipython_config.py

# ── Data stores (large, regenerable, may contain raw market/chain data) ──
# Keep these out of git — they are big and reproducible from the pipeline.
data/
datasets/
backfill/
raw/
*.csv
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz

# Local databases / caches
*.db
*.sqlite
*.sqlite3
*.duckdb
cache/
.cache_http/

# ── Backtest / simulation / model outputs ──
outputs/
output/
results/
artifacts/
runs/
checkpoints/
models/
*.joblib
*.pt
*.onnx
plots/
figures/
reports/*.html
reports/*.pdf

# ── Logs & audit trails (generated at runtime) ──
logs/
*.log
audit/
audit_log/

# ── OS / editor cruft ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace
