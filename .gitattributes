# Normalize line endings: let git handle EOL, store LF in the repo.
* text=auto eol=lf

# Explicitly text
*.py    text
*.md    text
*.txt   text
*.toml  text
*.cfg   text
*.ini   text
*.yml   text
*.yaml  text
*.json  text
*.sh    text eol=lf

# Treat notebooks as text but skip diff noise on their output
*.ipynb text

# Binary / data formats — never normalize
*.parquet binary
*.feather binary
*.arrow   binary
*.h5      binary
*.hdf5    binary
*.pkl     binary
*.pickle  binary
*.npy     binary
*.npz     binary
*.db      binary
*.sqlite  binary
*.duckdb  binary
*.png     binary
*.jpg     binary
*.pdf     binary
